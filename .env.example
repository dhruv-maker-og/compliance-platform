# Environment
ENVIRONMENT=development

# GitHub Copilot SDK
GITHUB_TOKEN=ghp_your_github_token_here

# Azure (optional for local dev)
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Purview (optional)
PURVIEW_ACCOUNT_NAME=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=DEBUG
